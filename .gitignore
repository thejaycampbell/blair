# Brand profiles — contain sensitive positioning, competitor intel, and strategy.
# Do not commit. Each user's brand profiles are private to their project.
.claude/cmo/brand.md
.claude/cmo/brands/*/brand.md
.claude/cmo/active-brand
.claude/cmo/pipeline.md
.claude/cmo/brands/*/pipeline.md
.claude/cmo/campaigns.md
.claude/cmo/brands/*/campaigns.md
.claude/cmo/insights.md
.claude/cmo/brands/*/insights.md
.claude/cmo/learnings.md
.claude/cmo/brands/*/learnings.md

# Web app — generated files and secrets
web/.next/
web/node_modules/
web/.env.local
web/drizzle/

# Claude Code worktree artifacts — created by git worktree, not part of the project
.claude/worktrees/

# Vercel — ignore CLI cache; commit project.json for shared project link
.vercel/*
!.vercel/project.json
